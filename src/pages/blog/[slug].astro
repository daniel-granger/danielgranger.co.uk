---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Daniel Granger`} description={post.data.description}>
  <article>
    <h1>{post.data.title}</h1>
    <time datetime={post.data.date.toISOString().split('T')[0]}>{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).replace(/(\w+) (\d+)$/, '$1, $2')}</time>
    <Content />
  </article>
</Layout>
