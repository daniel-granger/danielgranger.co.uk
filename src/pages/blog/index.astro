---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog - Daniel Granger">
  <div class="page-header mt-5">
    <h1>Blog</h1>
    <p class="page-subtitle">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
  </div>

  <section class="post-list mt-4">
    <div class="row g-4">
      {posts.map((post) => (
        <div class="col-12">
          <a href={`/blog/${post.id}`} class="post-card">
            <h4>{post.data.title}</h4>
            <p class="date"><i class="bi bi-calendar me-2"></i>{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
            <p>{post.data.description}</p>
          </a>
        </div>
      ))}
    </div>
  </section>
</Layout>
