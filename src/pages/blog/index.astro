---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import TaxonomyFilter from '../../components/TaxonomyFilter.astro';
import Icon from '../../components/Icon.astro';
import emptyStates from '../../data/empty-states.json';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const getPostCategories = (post: (typeof posts)[number]) => post.data.categories ?? post.data.tags ?? [];
const filterCategories = [...new Set(posts.flatMap((post) => getPostCategories(post)))].sort((a, b) => a.localeCompare(b));
const blogLabel = posts.length === 1 ? 'blog' : 'blogs';
---

<Layout title="Blog - Daniel Granger" description="Articles and thoughts on .NET, web development, and software engineering by Daniel Granger.">
  <div class="page-header mt-5">
    <h1>Blog</h1>
    <p class="page-subtitle">{posts.length} {blogLabel}</p>
  </div>

  {posts.length > 0 && (
    <TaxonomyFilter filters={filterCategories} ariaLabel="Filter posts by category" itemSelector=".blog-item" />
  )}

  <section class="post-list mt-4">
    {posts.length > 0 ? (
      <div class="row g-4">
        {posts.map((post) => {
          const categories = getPostCategories(post);

          return (
          <div class="col-12 blog-item" data-filter-values={categories.join(',')}>
            <a href={`/blog/${post.id}`} class="post-card">
              <h4>{post.data.title}</h4>
              <p class="date"><Icon name="calendar" class="inline-icon me-2" />{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
              <p>{post.data.description}</p>
              {categories.length > 0 && (
                <div class="tags">
                  {categories.map((category: string) => <span class="tag">{category}</span>)}
                </div>
              )}
            </a>
          </div>
        )})}
      </div>
    ) : (
      <p class="empty-state">{emptyStates.blog_index_empty}</p>
    )}
  </section>
</Layout>
