---
import Layout from '../../components/Layout.astro';
import contact from '../../data/contact.json';
---

<Layout title={`${contact.thanks_title} - Daniel Granger`} description={contact.thanks_message}>
  <div class="page-header mt-5">
    <h1>{contact.thanks_title}</h1>
  </div>
  <section class="contact-section mt-4">
    <p class="empty-state">{contact.thanks_message}</p>
    <p class="mt-3 mb-0"><a href="/contact">{contact.thanks_link_label}</a></p>
  </section>
</Layout>
