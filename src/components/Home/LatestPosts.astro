---
import { getCollection } from 'astro:content';
import Icon from '../Icon.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section class="latest-posts container-lg mt-5">
  <h2 class="mb-4">Latest Posts</h2>
  <div class="row g-4">
    {posts.map((post) => (
      <div class="col-md-6 col-lg-4">
        <a href={`/blog/${post.id}`} class="post-card">
          <h4>{post.data.title}</h4>
          <p class="date"><Icon name="calendar" class="inline-icon me-2" />{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
          <p>{post.data.description}</p>
          {post.data.tags && (
            <div class="tags">
              {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </a>
      </div>
    ))}
  </div>
</section>
